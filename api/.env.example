# ───────── AI providers ─────────
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# ───────── Supabase ─────────
# Project URL, e.g. https://abcdxyz.supabase.co  (Settings → Data API, or the "Connect" button)
SUPABASE_URL=https://your-project.supabase.co
# SECRET key (server-side only — NEVER ship to the client). New format: sb_secret_...
# (Settings → API Keys → "Publishable and secret API keys" → reveal the secret key)
SUPABASE_SERVICE_KEY=sb_secret_...
# Postgres connection string (Settings → Database → Connection string → URI).
# Change the scheme from postgresql:// to postgresql+asyncpg:// and fill in your DB password.
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# (No JWT secret needed — the backend validates tokens via Supabase's auth server, which works
#  with the new asymmetric JWT signing keys.)

# ───────── Billing ─────────
# RevenueCat webhook Authorization header value (shared secret you configure in RevenueCat)
REVENUECAT_WEBHOOK_SECRET=change-me

# ───────── App config (optional overrides) ─────────
# Comma-separated list of allowed CORS origins for non-mobile clients
CORS_ORIGINS=*
# Credits granted to a brand-new user on first sign-in
SIGNUP_BONUS_CREDITS=100
