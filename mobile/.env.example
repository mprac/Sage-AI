# Backend API base URL (FastAPI). Use your machine's LAN IP when testing on a physical phone,
# e.g. http://192.168.1.20:8000 — "localhost" won't resolve from the device.
EXPO_PUBLIC_API_URL=http://192.168.56.1:8000

# Supabase (client-side anon key is safe to ship)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# RevenueCat public SDK keys (per platform)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_...
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_...
